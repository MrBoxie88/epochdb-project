# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/epochdb?retryWrites=true&w=majority

# Port (Render sets this automatically)
PORT=5000

# JWT secret (generate a random string — e.g. openssl rand -hex 32)
JWT_SECRET=your-random-secret-here

# Base URL of your deployed site (used in verification email links)
BASE_URL=https://epochdb.net

# Email — Resend (https://resend.com)
# Uses HTTPS API — works on Render free tier (SMTP ports are blocked)
# RESEND_API_KEY = your API key from Resend dashboard (API Keys → Create API Key)
# SMTP_FROM = must use your verified domain (epochdb.net)
RESEND_API_KEY=your-resend-api-key
SMTP_FROM=noreply@epochdb.net

# Google reCAPTCHA v2 (get keys at https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
